@using TutorialIdentity.Models;
@model Pagination;

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            
            <li class="page-item @(Model.CurrentPage == 0 ? "disabled" : "")">
                <a class="page-link" href="@Model.GetPageUrl(1)">First</a>
            </li>
            <li class="page-item @(Model.CurrentPage == 0 ? "disabled" : "")">
                <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage - 1)">Previous</a>
            </li>

            @if (Model.TotalPages <= 7)
            {
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Model.GetPageUrl(i)">@i</a>
                    </li>
                }
            }
            else
            {
                @if (Model.CurrentPage > 4)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage - 3)">...</a>
                    </li>
                }

                @for (int i = Math.Max(1, Model.CurrentPage - 1); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 1); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Model.GetPageUrl(i)">@i</a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages - 3)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage + 3)">...</a>
                    </li>
                }
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage + 1)">Next</a>
            </li>
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Model.GetPageUrl(Model.TotalPages)">Last</a>
            </li>

        </ul>
    </nav>
}

